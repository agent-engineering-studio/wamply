# Wamply demo — variabili opzionali.
# I default in docker-compose.demo.yml sono già adatti alla demo locale.
# Modifica solo se sai cosa stai facendo.

# Quale tag delle immagini Wamply usare. `latest` segue master, `v0.x.y` pinna.
# WAMPLY_TAG=latest

# Password Postgres (cambia SOLO se 5432 è già usato da un altro DB sulla macchina).
# POSTGRES_PASSWORD=postgres

# URL pubblico del frontend (default: http://localhost:3000).
# SITE_URL=http://localhost:3000

# Modello Claude usato dall'agent. Le API key reali si configurano via UI, non qui.
# CLAUDE_MODEL=claude-sonnet-4-5
