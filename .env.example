# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL=http://localhost:3001
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
DATABASE_URL=postgresql://supabase_admin:postgres@supabase-db:5432/postgres
POSTGRES_PASSWORD=postgres

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Agent ─────────────────────────────────────────────────
AGENT_URL=http://agent:8000
AGENT_SECRET=dev-agent-secret-change-in-production

# ── Claude / Anthropic ────────────────────────────────────
# API key is configured at runtime, not here:
#   - Admin system key: /admin → tab "Claude API" (stored in system_config)
#   - User BYOK:        /settings/ai (stored encrypted in ai_config)
CLAUDE_MODEL=claude-sonnet-4-5

# ── Twilio WhatsApp API ──────────────────────────────────
# Test credentials: Console → Account → API keys & tokens →
# "Test credentials". Test creds NON inviano messaggi reali
# e rispondono con magic numbers (+15005550006 = success).
# https://www.twilio.com/docs/iam/test-credentials
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# WhatsApp sender: sandbox o numero approvato.
# Lascia vuoto se usi TWILIO_MESSAGING_SERVICE_SID.
TWILIO_FROM=whatsapp:+14155238886
# Opzionale: Messaging Service SID (preferito in produzione
# per sender pool/failover). Ha precedenza su TWILIO_FROM.
TWILIO_MESSAGING_SERVICE_SID=

# ── Stripe ────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_PRICE_STARTER=price_starter_xxxxx
STRIPE_PRICE_PRO=price_pro_xxxxx
STRIPE_PRICE_ENTERPRISE=price_enterprise_xxxxx

# Top-up credit pack Price IDs (one-time mode=payment on Stripe)
STRIPE_PRICE_TOPUP_SMALL=price_topup_small_xxxxx
STRIPE_PRICE_TOPUP_MEDIUM=price_topup_medium_xxxxx
STRIPE_PRICE_TOPUP_LARGE=price_topup_large_xxxxx
STRIPE_PRICE_TOPUP_XL=price_topup_xl_xxxxx

# ── Encryption ────────────────────────────────────────────
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# ── Auth (optional) ──────────────────────────────────────
SITE_URL=http://localhost:3000
API_EXTERNAL_URL=http://localhost:9999
ENABLE_GOOGLE_AUTH=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Mail (SMTP) ───────────────────────────────────────────
# Dev default: Mailhog (nessuna auth). Per produzione usa un provider reale
# (es. Aruba smtps.aruba.it:465 con TLS implicito, oppure 587 STARTTLS).
# Se la password contiene '#' usa single quote: SMTP_PASS='tu@pass#'
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_ADMIN_EMAIL=admin@wcm.local
SMTP_SENDER_NAME=Wamply Dev

# ── Next.js Public (client-side) ─────────────────────────
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8100
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
NEXT_PUBLIC_ENABLE_GOOGLE_AUTH=false
